<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ResultsController"
            style="-fx-background-color: linear-gradient(to right, #0a1f44, #1c3e73, #3373D4);">

    <VBox alignment="TOP_CENTER" spacing="15"
          AnchorPane.leftAnchor="40"
          AnchorPane.rightAnchor="40"
          AnchorPane.topAnchor="10"
          AnchorPane.bottomAnchor="40">

      <!-- TITLE -->
      <Label text="Quiz Complete"
             style="-fx-text-fill: white; -fx-font-size: 40px; -fx-font-weight: bold;"/>

      <!-- SCORE CARD -->
      <VBox alignment="CENTER" spacing="10" maxWidth="500"
            style="-fx-background-color: rgba(255,255,255,0.10); -fx-background-radius: 26;
                   -fx-padding: 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.45), 40, 0.25, 0, 12);">

        <Label text="Your Score"
               style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 18px;"/>
        <Label fx:id="scoreLabel" text=" "
               style="-fx-text-fill: white; -fx-font-size: 56px; -fx-font-weight: bold;"/>
      </VBox>

      <!-- LEADERBOARD CARD -->
      <VBox alignment="TOP_CENTER" spacing="8" maxWidth="700"
            style="-fx-background-color: rgba(255,255,255,0.10); -fx-background-radius: 26;
                   -fx-padding: 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.45), 40, 0.25, 0, 12);">

        <Label text="Leaderboard"
               style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>

        <TableView fx:id="leaderboardTable"
                   prefHeight="300"
                   prefWidth="600"
                   VBox.vgrow="ALWAYS"
                   style="-fx-background-color: transparent; -fx-control-inner-background: rgba(255,255,255,0.08);">

          <columns>
            <TableColumn fx:id="rankColumn" text="Rank"/>
            <TableColumn fx:id="nameColumn" text="Player" prefWidth="320"/>
            <TableColumn fx:id="scoreColumn" text="Score" prefWidth="120"/>
          </columns>
        </TableView>
      </VBox>

      <!-- BUTTONS -->
      <Region/>
      <Button fx:id="playAgainButton"
              onAction="#playAgain"
              text="Play Again"
              prefWidth="220"
              prefHeight="56"
              style="-fx-background-color: #2d7ef7; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: 600; -fx-background-radius: 14; -fx-cursor: hand;"/>
    </VBox>
</AnchorPane>
