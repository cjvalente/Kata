<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.QuizController"
            style="-fx-background-color: linear-gradient(to right, #0a1f44, #1c3e73, #3373D4);">

  <!-- HEADER -->
  <top>
    <VBox alignment="CENTER" spacing="16">
      <padding>
        <Insets top="40" bottom="25"/>
      </padding>

      <Label text="Quiz"
             style="
                       -fx-text-fill: white;
                       -fx-font-size: 42px;
                       -fx-font-weight: bold;
                   "/>

      <Label fx:id="questionNumLabel"
             text="Question 1 of 10"
             style="
                       -fx-text-fill: rgba(255,255,255,0.75);
                       -fx-font-size: 18px;
                   "/>

      <ProgressBar fx:id="progressBar"
                   progress="0.0"
                   prefWidth="560"
                   prefHeight="18"
                   style="
                             -fx-accent: #2d7ef7;
                             -fx-background-radius: 10;
                         "/>

    </VBox>
  </top>

  <!-- MAIN -->
  <center>

    <VBox alignment="CENTER" spacing="50">

      <Region VBox.vgrow="ALWAYS"/>

      <!-- GLASS CARD -->
      <VBox alignment="CENTER"
            spacing="40"
            maxWidth="880"
            style="
                      -fx-background-color: rgba(255,255,255,0.10);
                      -fx-background-radius: 26;
                      -fx-padding: 50;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.45), 40, 0.25, 0, 12);
                  ">

        <!-- QUESTION -->
        <Label fx:id="questionLabel"
               wrapText="true"
               textAlignment="CENTER"
               alignment="CENTER"
               prefWidth="720"
               maxWidth="720"
               minHeight="100"
               style="
           -fx-text-fill: white;
           -fx-font-size: 22px;
           -fx-font-weight: 600;
           -fx-line-spacing: 4;
       " />

        <!-- ANSWERS -->
        <VBox fx:id="questionsVbox"
              spacing="20"
              alignment="CENTER"
              maxWidth="640"
              prefHeight="200"
        />

        <!-- NEXT BUTTON -->
        <Button fx:id="nextButton"
                text="Next"
                prefWidth="240"
                prefHeight="56"
                onAction="#nextButtonPressed"
                style="
                            -fx-background-color: #2d7ef7;
                            -fx-text-fill: white;
                            -fx-font-size: 18px;
                            -fx-font-weight: 600;
                            -fx-background-radius: 14;
                            -fx-cursor: hand;
                        "/>

      </VBox>

      <Region VBox.vgrow="ALWAYS"/>

    </VBox>

  </center>

</BorderPane>
