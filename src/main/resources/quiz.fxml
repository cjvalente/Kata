<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.QuizController"
            style="-fx-background-color: linear-gradient(to bottom right, #1f4037, #99f2c8);">

  <!-- TOP -->
  <top>
    <VBox alignment="CENTER" spacing="10">
      <padding>
        <Insets top="25" bottom="15"/>
      </padding>

      <Label text="Quiz"
             style="-fx-text-fill: white; -fx-font-size: 34px; -fx-font-weight: bold;" />

      <Label fx:id="questionNumLabel"
             text="Question: 1"
             style="-fx-text-fill: white; -fx-font-size: 18px;" />

      <ProgressBar progress="0.0"
                   prefWidth="500"
                   style="-fx-accent: #004d40;" />
    </VBox>
  </top>

  <!-- CENTER -->
  <center>
    <VBox alignment="CENTER"
          spacing="40"
          fillWidth="true">

      <padding>
        <Insets left="60" right="60"/>
      </padding>

      <!-- Spacer pushes content to vertical center -->
      <Region VBox.vgrow="ALWAYS"/>

      <Label fx:id="questionLabel"
             text="The Question Will Go Here!"
             wrapText="true"
             maxWidth="900"
             style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: 500;" />

      <VBox fx:id="questionsVbox"
            alignment="CENTER"
            spacing="20"
            fillWidth="true"
            maxWidth="700" />

      <Button fx:id="nextButton"
              text="Next"
              prefWidth="200"
              prefHeight="50"
              style="
                        -fx-background-color: #004d40;
                        -fx-text-fill: white;
                        -fx-font-size: 16px;
                        -fx-background-radius: 10;
                        -fx-cursor: hand;
                    "/>

      <!-- Spacer pushes content to vertical center -->
      <Region VBox.vgrow="ALWAYS"/>

    </VBox>
  </center>

</BorderPane>
